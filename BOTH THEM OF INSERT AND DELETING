// Online C compiler to run C program online
#include <stdio.h>

int main() {
    int arr[200],a,pos,val;
    printf("ENTER YOUR SIZE OF ARRAY : ");
    scanf("%d",&a);
    for(int i = 0; i<a; i++)
    {
        printf("ENTER YOUR %d ELEMENT : ",i+1);
        scanf("%d",&arr[i]);
    }
    printf("YOUR ARRAY IS: ");
    for(int i = 0; i < a; i++)
    {
    printf("%d ", arr[i]);
    }
printf("\n");
    printf("ENTER YOUR POSITION (1 to %d) : ",a+1);
    scanf("%d",&pos);
    printf("ENTER YOUR VALUE : ");
    scanf("%d",&val);
    for(int i =a; i>=pos; i--)
    {
        arr[i] = arr[i-1];
    }
    arr[pos] = val;

    printf("AFTER THE INSERTION\n");
    for(int i=0; i<a; i++)
    {
        printf("%d\n",arr[i]);
    }
    int pos1;
    printf("ENTER YOUR POSITION (0 to %d) : ",a-1);
    scanf("%d",&pos1);
     for(int i = pos1; i < a; i++)
   {
    arr[i] = arr[i+1];
}
    printf("AFTER THE INZIZLATION\n");
    for(int i = 0; i<a-1; i++)
    {
        printf("%d\n",arr[i]);
    }
    
    return 0;
}
