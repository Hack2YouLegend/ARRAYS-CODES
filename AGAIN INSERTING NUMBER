#include <stdio.h>
int main()
{
    int pos,value,i,a;
    printf("ENTER YOUR VALUE : ");
    scanf("%d",&a);
    int arr[a];
    for(int i = 0; i<a; i++)
    {
        printf("ENTER YOUR ELEMENT : ");
        scanf("%d",&arr[i]);
    }
    printf("ENTER YOUR POSTION (1 to %d) : ",a+1);
    scanf("%d",&pos);
    printf("ENTER VALUE YOU WANT TO INSERT : ");
    scanf("%d",&value);
    for(int i = pos-1; i>=pos; i++)
    {
        arr[i+1] = arr[i];
    }
    arr[pos-1] = value;
    printf("AFTER INSERTING   :");
    for(int i = 0; i<a; i++)
    {
        printf("\n%d",arr[i]);
    }
}
